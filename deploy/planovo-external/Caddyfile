# Managed by the Planovo repository.
# Public edge for planovo.pro. KEMS stays isolated behind 127.0.0.1:18080.

{
	email admin@planovo.pro
}

(security_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy geolocation=(), microphone=(), camera=()
	}
}

planovo.pro, www.planovo.pro {
	import security_headers
	encode zstd gzip

	@api path /api /api/*
	handle @api {
		reverse_proxy 127.0.0.1:18080 {
			header_up X-Forwarded-Proto https
		}
	}

	handle /kems {
		redir /kems/ 308
	}

	@kems path /kems/*
	handle @kems {
		reverse_proxy 127.0.0.1:18080 {
			header_up X-Forwarded-Proto https
		}
	}

	root * /srv/site
	try_files {path} {path}/ /404.html
	file_server
}
